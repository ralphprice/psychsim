# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/
build/
dist/

# ---- Node / UI build artifacts (regenerable via `npm install` / `npm run build`) ----
ui/node_modules/
ui/dist/
ui/*.tsbuildinfo

# ---- Runtime saves written by the app (keep the folder, not its contents) ----
sims/*
!sims/.gitkeep

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
*.swp

# ---- Generated demo outputs (regenerable via the run_*.py scripts) ----
/town_life.html
/aged_town.svg
/demo_town.svg
/PIPELINE_OUTPUT.txt
